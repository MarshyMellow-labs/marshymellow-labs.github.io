# Copy this file to .env. Keep .env private and never place these values in the
# website, browser JavaScript, Git, screenshots, or support messages.

# Deployed Supabase Edge Function URL, for example:
# https://YOUR_PROJECT.supabase.co/functions/v1/marshy-control
MARSHY_CONTROL_ENDPOINT=

# Must exactly match the MARSHY_CONTROL_COMPANION_SECRET set on the Edge Function.
# Generate a long random secret (at least 32 characters).
MARSHY_CONTROL_SECRET=

# Physical output is opt-in and defaults off. Simulation and live mode are
# mutually exclusive.
PISHOCK_LIVE_ENABLED=false
PISHOCK_SIMULATE=false

# Owner-controlled device cap. 0 disables all commands. The companion has a
# software ceiling of 100/100. Using 100 here relies on a separately configured
# hardware-side safety cap; it does not configure or verify that hardware cap.
# Website percentages use a half scale: 100 means 50% of this local maximum,
# and the roulette-only 200 result means 100% of this local maximum. Start lower
# unless the receiver has been independently limited and tested.
PISHOCK_LOCAL_MAX=0

# Required only when PISHOCK_LIVE_ENABLED=true. Use a PiShock API key created
# after 2024-10-15 for the V2 broker. PISHOCK_SHARE_CODE is optional.
PISHOCK_USERNAME=
PISHOCK_API_KEY=
PISHOCK_USER_ID=
PISHOCK_CLIENT_ID=
PISHOCK_SHOCKER_ID=
PISHOCK_SHARE_CODE=

# Optional direct Pulsoid OAuth access token with data:heart_rate:read. Leave
# this blank when using the token-free PulsoidToOSC source below.
# Heart rate is display-only and is never used to choose or trigger an action.
PULSOID_ACCESS_TOKEN=

# Optional token-free local source via PulsoidToOSC. Direct token and OSC modes
# are mutually exclusive. In PulsoidToOSC add/enable a manual OSC endpoint with:
# IP 127.0.0.1, port 9002, path /avatar/parameters/, and integer HeartRateInt.
# Port 9002 avoids conflicting with VRChat's usual OSC port 9000.
PULSOID_OSC_ENABLED=false
PULSOID_OSC_PORT=9002
PULSOID_OSC_ADDRESS=/avatar/parameters/HeartRateInt
